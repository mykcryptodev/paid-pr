{
  "name": "paid-pr",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "paidpr": "./scripts/paidpr-create.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "paidpr": "tsx scripts/paidpr-create.ts",
    "paidpr:create": "tsx scripts/paidpr-create.ts open"
  },
  "dependencies": {
