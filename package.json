    "@octokit/webhooks": "^14.2.0",
    "@privy-io/react-auth": "^3.29.2",
    "@privy-io/server-auth": "^1.32.5",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "@x402/next": "^2.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.10.0",
